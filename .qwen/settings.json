{
  "permissions": {
    "allow": [
      "Bash(*)",
      "ReadFile(*)",
      "WriteFile(*)",
      "Edit(*)",
      "RunShellCommand(*)",
      "Glob(*)",
      "Grep(*)",
      "Agent(*)",
      "WebFetch(*)",
      "WebSearch(*)"
    ]
  },
  "mode": "yolo",
  "autoApprove": true,
  "telemetry": {
    "enabled": false
  },
  "features": {
    "codebaseIndexing": true,
    "semanticSearch": true,
    "multiFileEdits": true,
    "agentDelegation": true,
    "autoDocumentation": true,
    "autoLearning": true,
    "errorTracking": true,
    "selfImprovement": true
  },
  "autoLearning": {
    "enabled": true,
    "documentEveryChange": true,
    "trackErrors": true,
    "trackSolutions": true,
    "updateSkills": true,
    "createModuleDocs": true,
    "minimumDocumentation": {
      "whatWasDone": true,
      "whyItWasDone": true,
      "howItWorks": true,
      "problemsFound": true,
      "solutionsApplied": true,
      "lessonsLearned": true
    }
  },
  "documentation": {
    "autoUpdate": true,
    "commentCode": true,
    "updateConstants": true,
    "updateSkills": true,
    "createReadmePerModule": true,
    "createChangelog": true,
    "language": "es"
  },
  "constraints": {
    "alwaysCommentCode": true,
    "alwaysUpdateDocs": true,
    "neverSkipDocumentation": true,
    "learnFromErrors": true,
    "documentSolutions": true
  }
}
