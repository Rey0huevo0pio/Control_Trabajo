{
  "expo": {
    "name": "C_Ticket_Apk_STV",
    "slug": "c-ticket-apk-stv",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "cticketstv",
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "package": "com.cticketstv.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2196F3"
      },
      "usesCleartextTraffic": true
    },
    "ios": {
      "bundleIdentifier": "com.cticketstv.app",
      "supportsTablet": true
    }
  }
}
